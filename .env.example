# CorridorKey Web App — Environment Variables
# Copy to .env.local (web/) or .env (worker/) and fill in values.

# Supabase project settings (get from supabase.com dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Worker-only settings
CORRIDORKEY_DEVICE=cuda
CORRIDORKEY_BACKEND=torch
WORKER_ID=worker-01
TEMP_DIR=/tmp/ck_jobs
HEARTBEAT_STALE_MINUTES=5
